{
    "Function Definition": {
        "prefix": "fun",
        "body": [
            "fun ${1:function_name}: (${2:param}: ${3:Type}) -> ${4:ReturnType} = {",
            "\t${5:body}$0",
            "}"
        ],
        "description": "Define a function"
    },
    "Lambda Expression": {
        "prefix": "lambda",
        "body": [
            "|${1:param}| ${2:body}$0"
        ],
        "description": "Create a lambda expression"
    },
    "Variable Binding": {
        "prefix": "val",
        "body": [
            "val ${1:variable_name} = ${2:value}$0"
        ],
        "description": "Create a variable binding"
    },
    "Mutable Variable": {
        "prefix": "mut",
        "body": [
            "mut val ${1:variable_name} = ${2:value}$0"
        ],
        "description": "Create a mutable variable"
    },
    "Named Import": {
        "prefix": "import",
        "body": [
            "import ${1:module}.${2:path}.{${3:item}}$0"
        ],
        "description": "Import named items from a dotted module path"
    },
    "Wildcard Import": {
        "prefix": "importall",
        "body": [
            "import ${1:module}.${2:path}.*$0"
        ],
        "description": "Import all public items from a dotted module path"
    },
    "Module Import": {
        "prefix": "importmodule",
        "body": [
            "import ${1:module}.${2:path}$0"
        ],
        "description": "Import a dotted module path"
    },
    "Record Definition": {
        "prefix": "record",
        "body": [
            "record ${1:RecordName} {",
            "\t${2:field_name}: ${3:Type}",
            "\t$0",
            "}"
        ],
        "description": "Define a record type"
    },
    "Record Instance": {
        "prefix": "new",
        "body": [
            "${1:RecordName} {",
            "\t${2:field_name}: ${3:value},",
            "\t$0",
            "}"
        ],
        "description": "Create a record instance"
    },
    "Context Definition": {
        "prefix": "context",
        "body": [
            "context ${1:ContextName} {",
            "\t${2:resource}: ${3:Type}",
            "\t$0",
            "}"
        ],
        "description": "Define a context"
    },
    "Match Expression": {
        "prefix": "match",
        "body": [
            "${1:expression} match {",
            "\t${2:pattern} => { ${3:result} }",
            "\t_ => { ${4:default} }",
            "\t$0",
            "}"
        ],
        "description": "Pattern matching expression"
    },
    "Option Match": {
        "prefix": "option",
        "body": [
            "${1:maybe_value} match {",
            "\tSome(${2:value}) => { ${3:handle_some} }",
            "\tNone => { ${4:handle_none} }",
            "\t$0",
            "}"
        ],
        "description": "Pattern match on Option type"
    },
    "List Match": {
        "prefix": "listmatch",
        "body": [
            "${1:list} match {",
            "\t[] => { ${2:empty_case} }",
            "\t[${3:head} | ${4:tail}] => { ${5:cons_case} }",
            "\t$0",
            "}"
        ],
        "description": "Pattern match on List type"
    },
    "Then Else": {
        "prefix": "then",
        "body": [
            "${1:condition} then { ${2:then_branch} } else { ${3:else_branch} }$0"
        ],
        "description": "Conditional expression"
    },
    "While Loop": {
        "prefix": "while",
        "body": [
            "${1:condition} while {",
            "\t${2:body}$0",
            "}"
        ],
        "description": "While loop"
    },
    "With Context": {
        "prefix": "with",
        "body": [
            "with ${1:ContextName} { ${2:resource}: ${3:value} } {",
            "\t${4:body}$0",
            "}"
        ],
        "description": "Bind context resources"
    },
    "Pipe Operation": {
        "prefix": "pipe",
        "body": [
            "${1:value} |> ${2:function}$0"
        ],
        "description": "Pipe operation"
    },
    "OSV Function Call": {
        "prefix": "call",
        "body": [
            "(${1:arg1}, ${2:arg2}) ${3:function}$0"
        ],
        "description": "Call a function with OSV argument order"
    },
    "Main Function": {
        "prefix": "main",
        "body": [
            "fun main: () -> ${1:Int32} = {",
            "\t${2:0}$0",
            "}"
        ],
        "description": "Main function template"
    },
    "List Literal": {
        "prefix": "list",
        "body": [
            "[${1:element1}, ${2:element2}$0]"
        ],
        "description": "List literal"
    },
    "Array Literal": {
        "prefix": "array",
        "body": [
            "val ${1:arr}: Array<${2:Int32}, ${3:2}> = [${4:element1}, ${5:element2}]$0"
        ],
        "description": "Array binding with expected type"
    },
    "Record Spread Pattern": {
        "prefix": "spreadmatch",
        "body": [
            "${1:value} match {",
            "\t${2:RecordName} { ${3:field}, ...${4:rest} } => { ${5:result} }",
            "\t_ => { ${6:default} }",
            "\t$0",
            "}"
        ],
        "description": "Pattern match a record with spread destructuring"
    }
}
